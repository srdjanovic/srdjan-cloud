---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Srđan Milutinović — open to Senior Technical Operations, Platform Engineering, and Technical Delivery roles."
>
  <Nav />

  <main class="contact-main">
    <div class="container">
      <header class="page-header">
        <p class="page-header__tag">// contact</p>
        <h1 class="page-header__title">Get in touch.</h1>
        <p class="page-header__lead">
          Open to Senior Technical Operations, Platform Engineering, and Technical Delivery roles.
        </p>
      </header>

      <div class="contact-layout">

        <div class="contact-info">
          <div class="card contact-card">
            <a href="mailto:misrdan@gmail.com" class="contact-item">
              <span class="contact-item__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <polyline points="2,4 12,13 22,4"/>
                </svg>
              </span>
              <div>
                <p class="contact-item__label">Email</p>
                <p class="contact-item__value">misrdan@gmail.com</p>
              </div>
            </a>
          </div>

          <div class="card contact-card">
            <a href="https://www.linkedin.com/in/milutinovicsrdjan/" target="_blank" rel="noopener" class="contact-item">
              <span class="contact-item__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect x="2" y="9" width="4" height="12"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </span>
              <div>
                <p class="contact-item__label">LinkedIn</p>
                <p class="contact-item__value">milutinovicsrdjan</p>
              </div>
            </a>
          </div>

          <div class="card contact-card">
            <div class="contact-item no-link">
              <span class="contact-item__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              <div>
                <p class="contact-item__label">Location</p>
                <p class="contact-item__value">Karlsruhe, Germany</p>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form-wrap">
          <div class="card form-card">
            <h2 class="form-title">Send a message</h2>
            <p class="form-note">
              <!--
                Replace YOUR_FORM_ID below with your Formspree form ID.
                Sign up at https://formspree.io to get one.
              -->
            </p>
            <form
              id="contact-form"
              action="https://formspree.io/f/YOUR_FORM_ID"
              method="POST"
              novalidate
            >
              <div class="form-field">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required />
              </div>
              <div class="form-field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required />
              </div>
              <div class="form-field">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="6" placeholder="What's on your mind?" required></textarea>
              </div>
              <div id="form-status" class="form-status" hidden></div>
              <button type="submit" class="btn btn--primary submit-btn">
                <span id="submit-text">Send message</span>
                <span id="submit-spinner" class="btn-spinner" hidden></span>
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .contact-main { padding-top: var(--nav-h); padding-bottom: 5rem; }

  .contact-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: sticky;
    top: calc(var(--nav-h) + 2rem);
  }

  .contact-card { padding: 0; overflow: hidden; }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }
  .contact-item:not(.no-link):hover {
    background: rgba(0,212,255,0.05);
    opacity: 1;
  }
  .contact-item__icon {
    color: var(--accent);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .contact-item__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.15rem;
  }
  .contact-item__value {
    font-size: 0.875rem;
    margin: 0;
    color: var(--text);
  }

  .form-card { padding: 2rem 2.25rem; }
  .form-title {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .form-note { font-size: 0.825rem; color: var(--muted); margin-bottom: 1.5rem; }

  .form-field {
    margin-bottom: 1.25rem;
  }
  .form-field label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }
  .form-field input,
  .form-field textarea {
    width: 100%;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.7rem 1rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(0,212,255,0.08);
  }
  .form-field textarea { resize: vertical; }
  .form-field input::placeholder,
  .form-field textarea::placeholder { color: var(--muted); }

  .form-status {
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .form-status.success {
    background: rgba(57,255,20,0.08);
    border: 1px solid rgba(57,255,20,0.25);
    color: var(--green);
  }
  .form-status.error {
    background: rgba(255,68,68,0.08);
    border: 1px solid rgba(255,68,68,0.25);
    color: #FF6666;
  }

  .submit-btn { width: 100%; justify-content: center; }
  .btn-spinner {
    width: 14px; height: 14px;
    border: 2px solid rgba(8,13,23,0.4);
    border-top-color: var(--bg);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  @media (max-width: 680px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-info { position: static; }
    .form-card { padding: 1.5rem; }
  }
</style>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl   = document.getElementById('form-status')!;
  const submitText = document.getElementById('submit-text')!;
  const spinner    = document.getElementById('submit-spinner')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    submitText.textContent = 'Sending…';
    (spinner as HTMLElement).hidden = false;
    (statusEl as HTMLElement).hidden = true;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' },
      });

      if (res.ok) {
        statusEl.textContent = 'Message sent — I\'ll get back to you soon.';
        statusEl.className   = 'form-status success';
        (statusEl as HTMLElement).hidden = false;
        form.reset();
      } else {
        throw new Error('server error');
      }
    } catch {
      statusEl.textContent = 'Something went wrong. Try emailing me directly at misrdan@gmail.com.';
      statusEl.className   = 'form-status error';
      (statusEl as HTMLElement).hidden = false;
    } finally {
      submitText.textContent = 'Send message';
      (spinner as HTMLElement).hidden = true;
    }
  });
</script>
